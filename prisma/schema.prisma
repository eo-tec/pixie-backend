generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "windows", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

model code_versions {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  version    Int      @db.SmallInt
  url        String
  comments   String?

  @@schema("public")
}

model group_suscriber {
  user_id  Int
  active   Boolean      @default(true)
  id       Int          @id @unique @default(autoincrement())
  group_id Int?
  groups   groups?      @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users    public_users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model groups {
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?         @db.Timestamptz(6)
  name            String
  created_by      Int
  id              Int               @id @unique @default(autoincrement())
  group_suscriber group_suscriber[]
  users           public_users      @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  photo_groups    photo_groups[]

  @@schema("public")
}

model photo_groups {
  id       Int     @id @default(autoincrement())
  photo_id Int
  group_id Int?
  groups   groups? @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  photos   photos  @relation(fields: [photo_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model photos {
  id           Int                      @id @default(autoincrement())
  created_at   DateTime                 @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  photo_url    String?
  username     String?
  title        String?
  user_id      Int?
  photo_pixels Json                     @default("{}")
  deleted_at   DateTime?                @db.Timestamptz(6)
  is_public         Boolean                  @default(false)
  is_animation      Boolean                  @default(false)
  animation_frames  Int?
  animation_fps     Int?
  is_flagged        Boolean                  @default(false)
  photo_groups photo_groups[]
  visible_by   photo_visible_by_users[]
  hidden_by    photo_hidden_by_users[]
  users        public_users?            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reactions    photo_reactions[]
  comments            photo_comments[]
  currently_on_pixies pixie[]              @relation("CurrentPhoto")
  reports             content_reports[]

  @@schema("public")
}

model pixie {
  id                  Int                @id @default(autoincrement())
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  created_by          Int?
  brightness          Int?               @default(50)
  pictures_on_queue   Int?               @default(5)
  name                String?
  mac                 String
  code                String?            @default("0000")
  secs_between_photos Int?               @default(60)
  spotify_enabled     Boolean            @default(false)
  allow_draws         Boolean            @default(false)
  schedule_enabled    Boolean            @default(false)
  schedule_on_hour    Int?               @default(8)
  schedule_on_minute  Int?               @default(0)
  schedule_off_hour   Int?               @default(22)
  schedule_off_minute Int?               @default(0)
  clock_enabled       Boolean            @default(false)
  tier                PixieTier          @default(free)
  mqtt_password       String?
  current_photo_id    Int?
  current_song_id     String?
  current_song_name   String?
  users               public_users?      @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  photo_cursor        Int                @default(0)
  max_photos          Int                @default(0)
  current_photo       photos?            @relation("CurrentPhoto", fields: [current_photo_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  drawings            drawings[]
  drawing_sessions    drawing_sessions[]
  playlist_items      playlist_items[]

  @@schema("public")
}

model playlist_items {
  id         Int      @id @default(autoincrement())
  pixie_id   Int
  position   Int
  face_type  String
  config     Json     @default("{}")
  locked     Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  pixie      pixie    @relation(fields: [pixie_id], references: [id], onDelete: Cascade)

  @@unique([pixie_id, position])
  @@schema("public")
}

model spotify_credentials {
  id                    Int          @id @default(autoincrement())
  user_id               Int          @unique
  spotify_id            String
  spotify_secret        String
  expires_at            DateTime?    @db.Timestamptz(6)
  spotify_refresh_token String?
  users                 public_users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model urls {
  id       Int     @id @default(autoincrement())
  keyURL   String  @unique
  valueURL String?

  @@schema("public")
}

model public_users {
  id                      Int                      @id @default(autoincrement())
  created_at              DateTime                 @default(now()) @db.Timestamptz(6)
  deleted_at              DateTime?                @db.Timestamptz(6)
  username                String
  password                String?
  telegram_id             String?
  picture                 String?
  bio                     String?
  user_id                 String?                  @unique
  timezone_offset         Int?                     @default(0)
  accepted_terms_at       DateTime?                @db.Timestamptz(6)
  friends_sent            friends[]                @relation("SentFriendships")
  friends_received        friends[]                @relation("ReceivedFriendships")
  group_suscriber         group_suscriber[]
  groups                  groups[]
  visible_photos          photo_visible_by_users[]
  hidden_photos           photo_hidden_by_users[]
  photos                  photos[]
  pixie                   pixie[]
  received_private_photos private_photos[]         @relation("ReceivedPrivatePhotos")
  sent_private_photos     private_photos[]         @relation("SentPrivatePhotos")
  spotify_credentials     spotify_credentials?
  photo_reactions         photo_reactions[]
  photo_comments          photo_comments[]
  blocks_sent             user_blocks[]            @relation("BlocksSent")
  blocks_received         user_blocks[]            @relation("BlocksReceived")
  reports_sent            content_reports[]        @relation("ReportsSent")
  reports_received        content_reports[]        @relation("ReportsReceived")

  @@map("users")
  @@schema("public")
}

model friends {
  id         Int          @id @default(autoincrement())
  user_id_1  Int
  user_id_2  Int
  status     FriendStatus @default(pending)
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  user1      public_users @relation("SentFriendships", fields: [user_id_1], references: [id], onDelete: Cascade)
  user2      public_users @relation("ReceivedFriendships", fields: [user_id_2], references: [id], onDelete: Cascade)

  @@unique([user_id_1, user_id_2])
  @@schema("public")
}

model private_photos {
  id          Int          @id @default(autoincrement())
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  photo_url   String
  sent_by     Int
  received_by Int
  title       String?
  deleted_at  DateTime?    @db.Timestamptz(6)
  receiver    public_users @relation("ReceivedPrivatePhotos", fields: [received_by], references: [id], onDelete: Cascade)
  sender      public_users @relation("SentPrivatePhotos", fields: [sent_by], references: [id], onDelete: Cascade)

  @@schema("public")
}

model photo_visible_by_users {
  id         Int          @id @default(autoincrement())
  photo_id   Int
  user_id    Int
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  photo      photos       @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  user       public_users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([photo_id, user_id])
  @@map("photo_visible_by_users")
  @@schema("public")
}

model photo_hidden_by_users {
  id         Int          @id @default(autoincrement())
  photo_id   Int
  user_id    Int
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  photo      photos       @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  user       public_users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([photo_id, user_id])
  @@schema("public")
}

enum PixieTier {
  free
  premium

  @@schema("public")
}

enum FriendStatus {
  pending
  canceled
  accepted

  @@schema("public")
}

enum ReactionType {
  like
  laugh
  wow
  sad

  @@schema("public")
}

model drawings {
  id               Int                @id @default(autoincrement())
  pixie_id         Int
  user_id          String
  name             String
  pixel_data       Json
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  pixie            pixie              @relation(fields: [pixie_id], references: [id], onDelete: Cascade)
  drawing_sessions drawing_sessions[]

  @@schema("public")
}

model drawing_sessions {
  id           Int          @id @default(autoincrement())
  pixie_id     Int
  drawing_id   Int?
  is_active    Boolean      @default(true)
  participants Json
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)
  pixie        pixie        @relation(fields: [pixie_id], references: [id], onDelete: Cascade)
  drawing      drawings?    @relation(fields: [drawing_id], references: [id], onDelete: SetNull)

  @@schema("public")
}

model photo_reactions {
  id         Int          @id @default(autoincrement())
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  photo_id   Int
  user_id    Int
  type       ReactionType
  photo      photos       @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  user       public_users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([photo_id, user_id])
  @@schema("public")
}

model waitlist {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model photo_comments {
  id         Int          @id @default(autoincrement())
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  photo_id   Int
  user_id    Int
  content    String       @db.VarChar(500)
  deleted_at DateTime?    @db.Timestamptz(6)
  photo      photos       @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  user       public_users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model user_blocks {
  id         Int          @id @default(autoincrement())
  blocker_id Int
  blocked_id Int
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  blocker    public_users @relation("BlocksSent", fields: [blocker_id], references: [id], onDelete: Cascade)
  blocked    public_users @relation("BlocksReceived", fields: [blocked_id], references: [id], onDelete: Cascade)

  @@unique([blocker_id, blocked_id])
  @@schema("public")
}

model content_reports {
  id          Int          @id @default(autoincrement())
  reporter_id Int
  photo_id    Int?
  reported_user_id Int?
  reason      ReportReason
  description String?      @db.VarChar(500)
  status      ReportStatus @default(pending)
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  reviewed_at DateTime?    @db.Timestamptz(6)
  reporter    public_users @relation("ReportsSent", fields: [reporter_id], references: [id], onDelete: Cascade)
  reported_user public_users? @relation("ReportsReceived", fields: [reported_user_id], references: [id], onDelete: Cascade)
  photo       photos?      @relation(fields: [photo_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

enum ReportReason {
  inappropriate
  spam
  harassment
  other

  @@schema("public")
}

enum ReportStatus {
  pending
  reviewed
  actioned

  @@schema("public")
}
